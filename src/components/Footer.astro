---
const today = new Date();
---

<footer>
  <div class="footer-content">
    <p class="copyright">
      &copy; {today.getFullYear()} Sonja Heinze
    </p>
    <p class="note">
      Gebaut mit Astro, Obsidian & Gemini
    </p>
  </div>
</footer>

<style>
  footer {
    margin-top: 4rem;
    padding: 3rem 1rem;
    text-align: center;
    font-family: var(--font-hand);

    /* Die "Abreißkante" - gestrichelt statt durchgezogen */
    border-top: 2px dashed #bbb;
    color: #666;
  }

  .footer-content {
    max-width: 600px;
    margin: 0 auto;
    /* Eine leichte Rotation für den ganzen Block - sieht aus wie unten hingekritzelt */
    transform: rotate(1deg);
  }

  .copyright {
    font-size: 1.2rem;
    margin: 0;
    font-weight: bold;
  }

  .note {
    font-size: 1rem;
    margin: 0.5rem 0 0 0;
    opacity: 0.8;
  }
</style>
