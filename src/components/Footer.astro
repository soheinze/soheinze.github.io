---
const today = new Date();
---

<footer>
  <div class="footer-content">
    <p class="copyright">
      &copy; {today.getFullYear()} Sonja Heinze
    </p>
    <p class="note">
      Gebaut mit Astro, Obsidian & Unterstützung von Gemini
      <br />
      <a href="/impressum" class="legal-link">Impressum</a>
    </p>
  </div>
</footer>

<style>
  footer {
    margin-top: 4rem;
    padding: 3rem 1rem;
    text-align: center;
    font-family: var(--font-hand);

    /* Die "Abreißkante" - gestrichelt statt durchgezogen */
    border-top: 2px dashed #cbd5e1; /* Heller als vorher */
    color: #f8f9fa; /* Heller Text für Kontrast */
  }

  .footer-content {
    max-width: 600px;
    margin: 0 auto;
    /* Eine leichte Rotation für den ganzen Block - sieht aus wie unten hingekritzelt */
    transform: rotate(1deg);
  }

  .copyright {
    font-size: 1.2rem;
    margin: 0;
    font-weight: bold;
  }

  .note {
    font-size: 1rem;
    margin: 0.5rem 0 0 0;
    opacity: 0.9; /* Leicht erhöht für bessere Lesbarkeit */
  }

  .legal-link {
    font-size: 0.9rem;
    color: #e2e8f0; /* Heller statt dunklem Grau */
    text-decoration: none;
    margin-top: 0.5rem;
    display: inline-block;
    border-bottom: 1px dotted #cbd5e1;
  }

  .legal-link:hover {
    color: var(--color-accent);
  }
</style>
