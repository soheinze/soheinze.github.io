  <br />
  <small>Erstellt mit <a href="https://astro.build">Astro</a> & Obsidian</small>
</footer>

<style>
  footer {
    padding: 2rem;
    text-align: center;
    color: #888; /* Etwas blasserer Text */
    font-size: 0.9rem;
    margin-top: 4rem;
    border-top: 1px solid var(--color-border); /* Globale Variable nutzen */
  }

  a {
    color: var(--color-text);
    text-decoration: none;
  }

  a:hover {
    color: var(--color-accent);
  }
</style>
