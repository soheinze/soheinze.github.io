---
const { post } = Astro.props;
const formattedDate = post.data.pubDate.toLocaleDateString('de-DE');

// --- POST-IT GENERATOR ---
// 1. Eine Palette an typischen Post-It Farben definieren
const colors = [
  '#A3CCDA', // Pastel Blue
  '#FDB7EA', // Pastel Pink
  '#FFDCCC', // Pastel Orange
  '#FBF3B9', // Pastel Yellow
];

// 2. Zufällige Farbe auswählen
// Hinweis - Da Astro statisch baut, wird die Farbe bei jedem "npm run build" neu gewürfelt,
// bleibt dann aber auf der fertigen Seite fest.
const randomColor = colors[Math.floor(Math.random() * colors.length)];

// 3. Zufällige Rotation zwischen -3 und +3 Grad für den "unperfekten" Look
const randomRotation = Math.floor(Math.random() * 6) - 3;
---

<a
  href={`/blog/${post.slug}`}
  class="pin-card"
  style={`--bg-color: ${randomColor}; --rotate: ${randomRotation}deg;`}
>
  <article>
    {post.data.image && (
      <div class="img-container">
        <img src={post.data.image} alt={post.data.title} loading="lazy" />
      </div>
    )}

    <div class="content">
      <h3 class="title">{post.data.title}</h3>

      <div class="meta">
        <span class="date">{formattedDate}</span>
      </div>

      <div class="tags">
        {post.data.tags.slice(0, 3).map((tag) => (
           <span>#{tag}</span>
        ))}
      </div>
    </div>
  </article>
</a>

<style>
  .pin-card {
    display: block;
    text-decoration: none;
    color: #333; /* Dunkle Schrift für Kontrast auf hellen Zetteln */

    /* Hier nutzen wir die Zufallswerte */
    background-color: var(--bg-color);
    transform: rotate(var(--rotate));

    /* Post-It Shape */
    padding: 1.5rem;
    box-shadow: 2px 3px 10px rgba(0,0,0,0.15); /* Schatten hebt den Zettel ab */
    transition: transform 0.3s ease, box-shadow 0.3s ease;

    /* Wichtig für Masonry */
    break-inside: avoid;
    margin-bottom: 2rem;

    /* Schriftart für den Zettel */
    font-family: 'Patrick Hand', cursive;
  }

  /* Hover-Effekt: Zettel wird "gegriffen" und gerade gerückt */
  .pin-card:hover {
    transform: scale(1.05) rotate(0deg) !important;
    box-shadow: 5px 8px 15px rgba(0,0,0,0.2);
    z-index: 10;
    cursor: pointer;
  }

  .title {
    margin: 0 0 1rem 0;
    font-size: 1.5rem;
    line-height: 1.2;
    font-weight: bold;
  }

  .meta {
    font-size: 0.9rem;
    color: #555;
    margin-bottom: 1rem;
    border-bottom: 1px dashed #777; /* Eine gestrichelte Linie wie auf Notizpapier */
    padding-bottom: 0.5rem;
  }

  .img-container img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    mix-blend-mode: multiply; /* Lässt das Bild etwas mit dem Papier "verschmelzen" */
    margin-bottom: 1rem;
    filter: sepia(0.2); /* Leichter Retro-Touch */
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: #444;
    justify-content: flex-end; /* Tags rechts unten */
  }
</style>
