---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Timeline Exploring";

// Wir holen alle Einträge aus dem Ordner "lebenslauf"
const allMilestones = await getCollection("lebenslauf");

// Wir sortieren sie nach der 'order' Nummer (höchste/neueste zuerst)
const timelineData = allMilestones.sort((a, b) => b.data.order - a.data.order);
---

<BaseLayout pageTitle={pageTitle}>
    <div class="timeline-container">
        <header class="timeline-header">
            <h1>{pageTitle} ⏳</h1>
            <p class="intro">
                Mein Werdegang, Meilensteine und Projekte auf einen Blick.
            </p>
        </header>

        <div class="timeline">
            {
                timelineData.map((item) => (
                    <div class="timeline-item">
                        <div class="timeline-dot" aria-hidden="true"></div>

                        <div class="timeline-content">
                            <span class="year-badge">{item.data.year}</span>
                            <h3>{item.data.title}</h3>
                            <p>{item.body}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</BaseLayout>

<style>
    .timeline-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .timeline-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .timeline-header h1 {
        font-family: var(--font-heading);
        color: #f8f9fa; /* Heller Text für Kontrast */
        margin-bottom: 0.5rem;
        font-size: 2.5rem;
    }

    .intro {
        font-family: var(--font-body);
        color: #e5e7eb; /* Heller Text für Kontrast */
        font-size: 1.1rem;
    }

    /* --- DAS TIMELINE RASTER --- */
    .timeline {
        position: relative;
        padding-left: 2rem;
        /* Die vertikale Hauptlinie in deinem neuen Pinnwand-Grün */
        border-left: 4px solid #7ca99a;
    }

    .timeline-item {
        position: relative;
        margin-bottom: 3rem;
    }

    .timeline-item:last-child {
        margin-bottom: 0;
    }

    /* Der Punkt auf der Zeitleiste */
    .timeline-dot {
        position: absolute;
        /* Positioniert den Punkt exakt mittig auf der 4px dicken Linie */
        left: -2.6rem;
        top: 0;
        width: 24px;
        height: 24px;
        background-color: #faf9f6;
        border: 4px solid #4f46e5; /* Dein Indigo-Blau als Akzent */
        border-radius: 50%;
        z-index: 1;
        transition: transform 0.3s ease, background-color 0.3s ease;
    }

    /* Die Inhaltskarte (ähnlich wie deine PinCards, aber horizontal) */
    .timeline-content {
        background: #ffffff;
        padding: 1.5rem 2rem;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        position: relative;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    /* Hover-Effekte für mehr Interaktivität */
    .timeline-item:hover .timeline-content {
        transform: translateX(10px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    .timeline-item:hover .timeline-dot {
        transform: scale(1.3);
        background-color: #ec4899; /* Das Pink aus deinem Design */
        border-color: #ec4899;
    }

    /* Typografie in der Karte */
    .year-badge {
        display: inline-block;
        background-color: #4f46e5;
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.85rem;
        font-weight: 600;
        font-family: var(--font-body);
        margin-bottom: 0.75rem;
    }

    .timeline-content h3 {
        font-family: var(--font-heading);
        margin: 0 0 0.5rem 0;
        font-size: 1.5rem;
        color: #1f2937;
    }

    .timeline-content p {
        margin: 0;
        color: #4b5563;
        font-family: var(--font-body);
        line-height: 1.6;
    }
</style>
