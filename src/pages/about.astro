---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import profilBild from '../assets/love.jpg';

const pageTitle = "Über mich";
---

<BaseLayout pageTitle={pageTitle}>

  <div class="paper-sheet">
    <h1>Hallo, ich bin Sonja 👋</h1>

    <div class="image-container">
      <Image
        src={profilBild}
        alt="Ein Bild von Sonja"
        width={300}
        class="profile-pic"
      />
    </div>

    <div class="content">
      <p>
        Willkommen auf meiner persönlichen Pinnwand. Dies ist der Ort,
        an dem ich meine Gedanken sammle, Links speichere und Ideen teile.
      </p>

      <p>
        Diese Seite ist ein "Digital Garden" – sie wächst organisch, genau wie meine Notizen in Obsidian.
      </p>

      <h3>Was mich interessiert</h3>
      <ul>
        <li>Digital Humanities</li>
        <li>Wissensmanagement</li>
        <li>Musik</li>
        <li>Segeln</li>
        <li>Kunst und Kultur</li>
        <li>Human Design und Astrologie</li>
        <li>Verantwortungsvoller Einsatz von Künstlicher Intelligenz</li>
        <li>uvm.</li>
      </ul>
    </div>
  </div>

</BaseLayout>

<style>
  /* Wir nutzen fast den gleichen Style wie beim Blogpost */
  .paper-sheet {
    max-width: 700px;
    margin: 3rem auto;
    background: #fff;
    padding: 3rem;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    transform: rotate(1deg); /* In die andere Richtung gedreht als der Blogpost */
  }

  h1 {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 2rem;
    color: var(--color-accent);
  }

  .content {
    font-size: 1.15rem;
    line-height: 1.7;
  }

  ul {
    list-style-type: square;
    padding-left: 1.5rem;
  }

  li {
    margin-bottom: 0.5rem;
  }

  .image-container {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .profile-pic {
    border-radius: 20%; /* Rundet das Bild ab, je größer der Wert desto runder das Bild */
    border: 5px solid white; /* Ein kleiner weißer Rahmen wie bei einem Foto */
    box-shadow: 0 4px 10px rgba(0,0,0,0.1); /* Leichter Schatten */
    max-width: 100%;
    height: auto;
  }
</style>
