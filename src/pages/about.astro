---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";

const aboutEntry = await getEntry("about", "index");
if (!aboutEntry) throw new Error("No index.md found in src/content/about/");
const { Content } = await render(aboutEntry);
---

<Layout title="Über Mich | Sonja Heinze">
  <div class="container article-container">
    <article class="prose">
      <header class="article-header">
        <h1>{aboutEntry.data.title}</h1>
      </header>
      
      <div class="article-content">
        <Content />
      </div>
    </article>
  </div>
</Layout>

<style>
  .article-container {
    padding-top: var(--spacing-xl);
    padding-bottom: var(--spacing-xl);
    max-width: 800px;
    margin: 0 auto;
  }

  .article-header {
    margin-bottom: var(--spacing-xl);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: var(--spacing-lg);
  }

  .article-content {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-primary);
  }
  
  .article-content :global(p) {
    margin-bottom: var(--spacing-lg);
  }

  .article-content :global(h2) {
    font-size: 1.8rem;
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
  }

  .article-content :global(h3) {
    font-size: 1.4rem;
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
  }

  .article-content :global(ul), .article-content :global(ol) {
    margin-bottom: var(--spacing-lg);
    padding-left: var(--spacing-lg);
  }

  .article-content :global(li) {
    margin-bottom: var(--spacing-sm);
  }

  .article-content :global(a) {
    color: var(--highlight-teal);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 4px;
    transition: var(--transition-smooth);
  }

  .article-content :global(a:hover) {
    text-decoration-color: var(--highlight-teal);
  }
</style>
