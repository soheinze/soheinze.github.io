---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = "404 - Seite nicht gefunden";
---

<BaseLayout pageTitle={pageTitle}>
  <div style="text-align: center; margin-top: 5rem; margin-bottom: 5rem;">
    <h1 style="font-size: 4rem; margin: 0;">404</h1>
    <p style="font-size: 1.5rem;">Hoppla! Diese Notiz scheint verloren gegangen zu sein.</p>

    <a href="/" class="button">Zurück zur Pinnwand</a>
  </div>
</BaseLayout>

<style>
  /* Ein kleiner Button-Style für den Rückweg */
  .button {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.5rem 1rem;
    background-color: var(--color-accent);
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: bold;
  }

  .button:hover {
    opacity: 0.9;
  }
</style>
