---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Kontakt";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="paper-sheet">
    <h1>Schreib mir gerne 📬</h1>

    <div class="content">
      <p>
        Hast du Fragen, Anregungen oder möchtest einfach Hallo sagen? Ich freue
        mich immer über digitale Post!
      </p>

      <form
        action="https://form.taxi/s/3c1fh2je"
        method="POST"
        class="contact-form"
      >
        <!-- Honeypot -->
        <input
          type="text"
          name="_gotcha"
          value=""
          class="hidden-field"
          tabindex="-1"
          autocomplete="off"
        />

        <div class="form-group">
          <label for="name">Name</label>
          <input
            type="text"
            id="name"
            name="Name"
            required
            placeholder="Wie darf ich dich nennen?"
          />
        </div>

        <div class="form-group">
          <label for="email">E-Mail Adresse</label>
          <input
            type="email"
            id="email"
            name="Email"
            required
            placeholder="deine@email.de"
          />
        </div>

        <div class="form-group">
          <label for="message">Nachricht</label>
          <textarea
            id="message"
            name="Nachricht"
            required
            rows="5"
            placeholder="Worum geht es?"></textarea>
        </div>

        <div class="form-group checkbox-group">
          <input
            type="checkbox"
            id="privacy"
            name="Datenschutz_akzeptiert"
            required
          />
          <label for="privacy">
            Ich stimme zu, dass meine Angaben zur Beantwortung meiner Anfrage
            verarbeitet werden. (Weitere Informationen in der <a
              href="/datenschutz">Datenschutzerklärung</a
            >)
          </label>
        </div>

        <button type="submit" class="submit-btn" aria-label="Nachricht senden"
          >Nachricht senden</button
        >
      </form>

      <div class="contact-methods">
        <div class="method">
          <h1>Meine Profile</h1>

          <p>
            Hier findest du meine Profile auf verschiedenen Plattformen, wo du
            mehr erfahren und über die du auch mit mir in Kontakt treten kannst:
          </p>

          <div class="social-links">
            <a
              href="https://www.linkedin.com/in/sonja-heinze/"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label="LinkedIn (öffnet in neuem Tab)"
            >
