---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const formattedDate = post.data.pubDate.toLocaleDateString('de-DE');
---

<BaseLayout pageTitle={post.data.title}>

  <article class="paper-sheet">
    <a href="/" class="back-link">← Zurück zur Pinnwand</a>

    <header>
      <p class="date">{formattedDate}</p>
      <h1>{post.data.title}</h1>
      <hr class="divider" />
    </header>

    {post.data.image && (
      <div class="image-container">
        <img src={post.data.image} alt={post.data.title} />
      </div>
    )}

    <div class="prose">
      <Content />
    </div>
  </article>

</BaseLayout>

<style>
  /* Das Blatt Papier */
  .paper-sheet {
    max-width: 750px;
    margin: 2rem auto 4rem auto;
    background: #fff;
    padding: 3rem 4rem;

    /* Der 3D-Effekt: Schwebt leicht über dem Tisch */
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    border-radius: 2px;

    /* Minimal gedreht für den organischen Look */
    transform: rotate(-0.5deg);
  }

  /* Auf Handys weniger Rand */
  @media (max-width: 600px) {
    .paper-sheet {
      padding: 1.5rem;
      transform: none; /* Auf kleinen Screens lieber gerade */
      width: 90%;
    }
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-hand);
    color: #666;
    margin-bottom: 2rem;
    font-size: 1.2rem;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-style: wavy;
  }

  header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .date {
    font-family: var(--font-hand);
    color: #888;
    font-size: 1.1rem;
  }

  h1 {
    font-size: 2.5rem;
    margin: 0.5rem 0 1rem 0;
    line-height: 1.2;
    color: var(--color-text);
  }

  /* Eine krakelige Linie unter dem Titel */
  .divider {
    border: 0;
    height: 1px;
    background: #ccc;
    width: 50%;
    margin: 0 auto;
    position: relative;
  }

  /* Das Bild wie ein Foto einkleben */
  .image-container {
    margin: 2rem -2rem; /* Breiter als der Text */
    text-align: center;
  }

  .image-container img {
    max-width: 100%;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transform: rotate(1deg); /* Foto leicht schief eingeklebt */
    border: 8px solid white; /* Weißer Foto-Rahmen */
  }

  /* Typografie für den Lesetext */
  .prose {
    font-family: var(--font-body); /* Gut lesbare Schrift für langen Text */
    font-size: 1.1rem;
    line-height: 1.8;
    color: #333;
  }

  /* Damit Markdown-Elemente gut aussehen */
  .prose h2, .prose h3 {
    font-family: var(--font-hand);
    margin-top: 2rem;
    color: var(--color-text);
  }

  .prose blockquote {
    border-left: 4px solid var(--color-accent);
    padding-left: 1rem;
    font-style: italic;
    color: #555;
    background: #f9f9f9;
    padding: 1rem;
    margin: 1.5rem 0;
  }
</style>
