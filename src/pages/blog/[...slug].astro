---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  // Auch hier: Nur deutsche oder sprachlose Posts generieren
  const posts = await getCollection('blog', ({ data }) => {
    return data.lang === 'de' || !data.lang;
  });

  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const formattedDate = post.data.pubDate.toLocaleDateString('de-DE');
---

<BaseLayout pageTitle={post.data.title}>

  <article class="paper-sheet">
    <a href="/" class="back-link">← Zurück zur Pinnwand</a>

    <header>
      <p class="date">{formattedDate}</p>
      <h1>{post.data.title}</h1>
      <hr class="divider" />
    </header>

    {post.data.image && (
      <div class="image-container">
        <img src={post.data.image} alt={post.data.title} />
      </div>
    )}

    <div class="prose">
      <Content />
    </div>
  </article>

</BaseLayout>

<style>
  /* Das Blatt Papier */
  .paper-sheet {
    max-width: 750px;
    margin: 2rem auto 4rem auto;
    background: #fff;
    padding: 3rem 4rem;

    /* Der 3D-Effekt: Schwebt leicht über dem Tisch */
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    border-radius: 2px;

    /* Minimal gedreht für den organischen Look */
    transform: rotate(-0.5deg);
  }

  /* Auf Handys weniger Rand */
  @media (max-width: 600px) {
    .paper-sheet {
      padding: 1.5rem;
      transform: none; /* Auf kleinen Screens lieber gerade */
      width: 90%;
    }
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-hand);
    color: #666;
    margin-bottom: 2rem;
    font-size: 1.2rem;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-style: wavy;
  }

  header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .date {
    font-family: var(--font-hand);
    color: #888;
    font-size: 1.1rem;
  }

  h1 {
    font-size: 2.5rem;
    margin: 0.5rem 0 1rem 0;
    line-height: 1.2;
    color: var(--color-text);
  }

  /* Eine krakelige Linie unter dem Titel */
  .divider {
    border: 0;
    height: 1px;
    background: #ccc;
    width: 50%;
    margin: 0 auto;
    position: relative;
  }

  /* Das Bild wie ein Foto einkleben */
  .image-container {
    margin: 2rem -2rem; /* Breiter als der Text */
    text-align: center;
  }

  .image-container img {
    max-width: 100%;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transform: rotate(1deg); /* Foto leicht schief eingeklebt */
    border: 8px solid white; /* Weißer Foto-Rahmen */
  }

  /* Typografie für den Lesetext */
  .prose {
    font-family: var(--font-body); /* Gut lesbare Schrift für langen Text */
    font-size: 1.1rem;
    line-height: 1.8;
    color: #333;
  }

  /* Damit Markdown-Elemente gut aussehen */
  .prose h2 {
    font-family: var(--font-hand);
    margin-top: 2rem;
    color: var(--color-text);
  }

  .prose h3 {
    font-family: var(--font-hand);
    margin-top: 1.5rem;
    color: var(--color-text);
  }

  .prose blockquote {
    border-left: 4px solid var(--color-accent);
    padding-left: 1rem;
    font-style: italic;
    color: #555;
    background: #f9f9f9;
    padding: 1rem;
    margin: 1.5rem 0;
  }

  /* Styles für Links IM Text */
  .prose a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 2px solid transparent; /* Platzhalter für Linie */
    font-weight: bold;
    transition: all 0.2s ease;
  }

  .prose a:hover {
    color: #2c3e50;
    border-bottom: 2px solid var(--color-accent); /* Solide Linie beim Hover */
    background-color: rgba(52, 152, 219, 0.1); /* Leichter Marker-Effekt */
    padding: 0 4px;
    border-radius: 4px;
  }

  /* Bilder im Fließtext (Body) */
  /* :global(img) sagt Astro - "Wende das auf ALLE Bilder in .prose an,
   egal woher sie kommen" */
  .prose :global(img) {
    display: block;        /* Macht das Bild zum Block-Element (wichtig fürs Zentrieren) */
    margin: 2rem auto;     /* Oben/Unten: Abstand, Links/Rechts: Automatisch (Zentriert) */
    max-width: 70%;        /* Begrenzt die Breite auf 70% des Textes -> wirkt kleiner */
    height: auto;          /* Behält das Seitenverhältnis bei */
    border-radius: 4px;    /* Leicht abgerundete Ecken wie beim Titelbild */
    box-shadow: 0 2px 8px rgba(0,0,0,0.1); /* Leichter Schatten für Tiefe */
  }

  /* Auf sehr kleinen Handys darf das Bild wieder etwas breiter sein */
  @media (max-width: 600px) {
    .prose img {
      max-width: 100%;
    }
  }
</style>
