---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";

const homeEntry = await getEntry("home", "index");
if (!homeEntry) throw new Error("No index.md found in src/content/home/");
const { Content } = await render(homeEntry);

const allBlog = await getCollection("blog");
const allPins = await getCollection("pins");
const allItems = [...allBlog, ...allPins];

const recentPosts = [...allItems]
  .filter((post) => post.data.date)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const uniqueTags = [
  ...new Set(allItems.flatMap((item: any) => item.data.tags || [])),
];
const sortedTags = uniqueTags.sort((a, b) => a.localeCompare(b));
---

<Layout title="Sonja Heinze | Meine Pinnwand">
  <div class="container hero-section">
    <h1>{homeEntry.data.title}</h1>
    <div class="intro-text">
      <Content />
    </div>

    <!-- Dynamic Tag Banner -->
    <div class="dynamic-tags-banner">
      <span class="banner-label">Themen-Tags zum Stöbern:</span>
      {
        sortedTags.map((tag) => (
          <a href={`/topic/${tag.toLowerCase()}`} class="banner-tag">
            #{tag}
          </a>
        ))
      }
    </div>

    <!-- Topic Navigation Layout -->
    <div class="pinboard-grid">
      <a href="/topic/business" class="pin-card topic-card">
        <h2 class="topic-name pink-text">
          <svg
            class="topic-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.9 1.3 1.5 1.5 2.5"
            ></path><path d="M9 18h6"></path><path d="M10 22h4"></path></svg
          >
          Business
        </h2>
        <p class="topic-desc">
          Beiträge und Informationen zu meiner Unternehmensgründung
        </p>
      </a>

      <a href="/topic/kunstecke" class="pin-card topic-card">
        <h2 class="topic-name purple-text">
          <svg
            class="topic-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"
            ></circle><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"
            ></circle><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"
            ></circle><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"
            ></circle><path
              d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"
            ></path></svg
          >
          Kunstecke
        </h2>
        <p class="topic-desc">
          Einblicke in meine Kunst und Gedanken, sowie Informationen zu
          Kunstprojekten
        </p>
      </a>

      <a href="/topic/research" class="pin-card topic-card">
        <h2 class="topic-name teal-text">
          <svg
            class="topic-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"
            ></path><path
              d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"
            ></path><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"
            ></path><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"></path></svg
          >
          Forschung
        </h2>
        <p class="topic-desc">
          Beiträge und Informationen zu bzw. aus meinem Studium und Forschung
        </p>
      </a>

      <a href="/topic/segeln" class="pin-card topic-card">
        <h2 class="topic-name purple-text">
          <svg
            class="topic-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M22 18H2a4 4 0 0 0 4 4h12a4 4 0 0 0 4-4Z"></path><path
              d="M21 14 10 2 3 14h18Z"></path><path d="M10 2v16"></path></svg
          >
          Segeln
        </h2>
        <p class="topic-desc">Alles rund ums Segeln und meine Erfahrungen</p>
      </a>

      <a href="/lebenslauf" class="pin-card topic-card">
        <h2 class="topic-name teal-text">
          <svg
            class="topic-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
            ></path><circle cx="12" cy="10" r="3"></circle></svg
          >
          Lebenslauf
        </h2>
        <p class="topic-desc">
          Eine kleine Chronologie meiner Stationen und Meilensteine
        </p>
      </a>

      <a href="/links" class="pin-card topic-card">
        <h2 class="topic-name pink-text">
          <svg
            class="topic-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
            ></path><path
              d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
            ></path></svg
          >
          Links
        </h2>
        <p class="topic-desc">Profil-Links und andere Empfehlungen</p>
      </a>
    </div>

    <!-- Recent Posts Section -->
    <div class="recent-posts-section">
      <h3 class="section-title">Neueste Einträge</h3>
      <ul class="recent-posts-list">
        {
          recentPosts.map((post) => (
            <li>
              <a
                href={`/${post.collection}/${post.id}`}
                class="recent-post-link"
              >
                <span class="recent-post-date">
                  {new Date(post.data.date).toLocaleDateString("de-DE")}
                </span>
                <span class="recent-post-title">{post.data.title}</span>
                <span class="recent-post-collection">({post.collection})</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Layout>

<style>
  .hero-section {
    padding-top: var(--spacing-xl);
    padding-bottom: var(--spacing-xl);
  }

  .intro-text {
    font-size: 1.2rem;
    max-width: 100%;
    margin-top: var(--spacing-md);
  }

  .dynamic-tags-banner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-sm) var(--spacing-md);
    margin-top: var(--spacing-lg);
    padding: var(--spacing-md) 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .banner-label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-right: var(--spacing-sm);
  }

  .banner-tag {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text-secondary);
    text-transform: lowercase;
    transition: var(--transition-smooth);
  }

  .banner-tag:hover {
    color: var(--accent-color);
  }

  .topic-card {
    justify-content: center;
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  .topic-icon {
    width: 1.15em;
    height: 1.15em;
    flex-shrink: 0;
    margin-top: 0.15em;
    transition: var(--transition-smooth);
  }

  .topic-card:hover .topic-name {
    transform: scale(1.05);
  }

  .topic-name {
    display: flex;
    align-items: center;
    gap: 0.3em;
    font-size: 2.2rem;
    margin-bottom: var(--spacing-sm);
    transition: var(--transition-smooth);
  }

  .topic-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  .pink-text {
    color: var(--highlight-pink);
  }
  .purple-text {
    color: var(--highlight-purple);
  }
  .teal-text {
    color: var(--highlight-teal);
  }

  .recent-posts-section {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-xl);
  }

  .section-title {
    font-size: 1.8rem;
    margin-bottom: var(--spacing-md);
    font-family: var(--font-heading);
    color: var(--text-primary);
  }

  .recent-posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .recent-posts-list li {
    margin-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--border-color);
  }

  .recent-posts-list li:last-child {
    border-bottom: none;
  }

  .recent-post-link {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-md);
    text-decoration: none;
    color: var(--text-primary);
    padding: var(--spacing-md) 0;
    transition: var(--transition-smooth);
  }

  .recent-post-link:hover {
    color: var(--highlight-teal);
    padding-left: var(--spacing-sm);
  }

  .recent-post-date {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text-secondary);
    min-width: 90px;
  }

  .recent-post-title {
    font-weight: 500;
    font-size: 1.1rem;
    flex-grow: 1;
  }

  .recent-post-collection {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
