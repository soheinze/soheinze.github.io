---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PinCard from '../components/PinCard.astro';

const pageTitle = "Meine Pinnwand";

// 1. Wir holen ALLE Posts aus der Collection 'blog'
const allPosts = await getCollection('blog', ({ data }) => {
  // Zeige den Post, wenn er explizit 'de' ist ODER gar keine Sprache hat (Standard = Deutsch)
  return data.lang === 'de' || !data.lang;
});

// --- DEBUGGING START ---
// Wir prüfen vor dem Sortieren, ob Daten fehlen und geben es im Terminal aus
allPosts.forEach(post => {
  if (!post.data.pubDate) {
    console.error('FEHLER Der Post "${post.slug}" hat kein gültiges Datum (pubDate)!');
  }
});
// --- DEBUGGING ENDE ---

// Sicheres Sortieren. Wenn kein Datum da ist, nehmen wir "0" (ganz alt), damit es nicht abstürzt
allPosts.sort((a, b) => {
  const dateA = a.data.pubDate ? a.data.pubDate.valueOf() : 0;
  const dateB = b.data.pubDate ? b.data.pubDate.valueOf() : 0;
  return dateB - dateA;
});
---

<BaseLayout pageTitle={pageTitle}>

  <div class="intro">
    <h1>Hallo und Herzlich Willkommen 👋</h1>
    <p>Dies ist bzw. wird meine persönliche Homepage auf der ihr
    Informationen zu verschiedenen Bereichen meines Lebens und Interessen von mir finden könnt.</p>
    </br>
    Im Moment befindet sich diese Seite noch im Aufbau
    und wird in den kommenden Tagen und Wochen weiter mit Inhalt gefüllt werden.
    </br>
    Stay Tuned & Viel Spaß beim Stöbern!
  </div>

  <div class="masonry-grid">
    {allPosts.map((post) => (
      <PinCard post={post} />
    ))}
  </div>

</BaseLayout>

<style>
  .intro {
    text-align: center;
    padding: 2rem 1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  /* --- DAS MASONRY RASTER --- */
  .masonry-grid {
    column-count: 3;
    column-gap: 2rem; /* Mehr Platz zwischen den Spalten */

    max-width: 1200px;
    margin: 0 auto;
    /* Wichtig: Padding an den Seiten, damit gedrehte Zettel nicht aus dem Bild ragen */
    padding: 2rem;
  }

  /* Responsiv: Auf Tablets nur 2 Spalten */
  @media (max-width: 900px) {
    .masonry-grid {
      column-count: 2;
    }
  }

  /* Responsiv: Auf Handys nur 1 Spalte (normale Liste) */
  @media (max-width: 600px) {
    .masonry-grid {
      column-count: 1;
    }
  }
</style>
